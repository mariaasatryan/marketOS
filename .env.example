# MarketOS Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# App Configuration
VITE_APP_MODE=LIVE
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000
VITE_API_TIMEOUT=30000
VITE_CACHE_TTL=300000

# Google OAuth (optional)
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
VITE_GOOGLE_REDIRECT_URI=https://your-domain.com/MarketOS/

# Marketplace API Tokens
WB_API_TOKEN=your_wildberries_token
OZON_API_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
YM_API_TOKEN=your_yandex_market_token
YM_CAMPAIGN_ID=your_yandex_campaign_id

# AI Configuration (optional)
VITE_AI_API_KEY=your_ai_api_key
VITE_AI_PROVIDER=openai
VITE_AI_MODEL=gpt-4

# Feature Flags
VITE_FEATURE_CALENDAR_AUTO_REMINDER=true
VITE_FEATURE_SHEETS_PREVIEW=true
VITE_FEATURE_ADS_MODULE=true
VITE_FEATURE_AI_ASSISTANT=false
